{
  "domain": "careers.allianz.com",
  "name": "安联保险招聘",
  "card_selector": "div[data-ph-at-id='jobs-list']",
  "fields": {
    "title": "a[data-ph-at-id='job-link']",
    "location": "button[data-ph-at-id='job-multi_location'] span[aria-hidden='true']",
    "category": ".job-category span:last-child",
    "job_level": ".job-jobLevel span:last-child",
    "unit": ".job-unit span:last-child"
  },
  "url_mode": "href",
  "url_selector": "a[data-ph-at-id='job-link']",
  "wait_after_click_ms": 2000,
  "pre_actions": [
    {
      "action": "wait_for_content",
      "timeout_ms": 15000
    }
  ]
}