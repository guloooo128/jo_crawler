{
  "domain": "jobs.boeing.com",
  "name": "波音招聘",
  "card_selector": "#search-results-list > ul > li",
  "fields": {
    "title": ".search-results__job-title",
    "location": ".search-results__job-info.location",
    "date": ".search-results__job-info.date"
  },
  "url_mode": "href",
  "url_selector": "a.search-results__job-link",
  "wait_after_click_ms": 2000,
  "pre_actions": [
    {
      "action": "wait_for_content",
      "timeout_ms": 15000
    }
  ]
}