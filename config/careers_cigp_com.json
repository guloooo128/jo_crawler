{
  "domain": "careers.cigp.com",
  "name": "CIGP 招聘",
  "card_selector": "app-root > div.container:nth-of-type(2) > app-position-list > div.container > div.position-list-container:nth-of-type(2) > div",
  "fields": {
    "title": "app-position-card div.position-card h3.job-title",
    "location": "app-position-card div.position-card div.location",
    "department": "app-position-card div.position-card div.details span.team",
    "date": "app-position-card div.position-card div.details span.deadline",
    "type": "app-position-card div.position-card div.details span.type"
  },
  "url_mode": "click_newtab",
  "url_selector": "app-position-card div.position-card",
  "wait_after_click_ms": 2000,
  "pre_actions": [
    {
      "action": "wait_for_content",
      "timeout_ms": 15000
    }
  ]
}