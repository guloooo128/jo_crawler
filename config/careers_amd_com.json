{
  "domain": "careers.amd.com",
  "name": "AMD 招聘",
  "card_selector": "#all-content > search-app > search-base-search-holder.ng-star-inserted > search-results > div.search-results.jibe-container > div.search-results__list.ng-star-inserted > div.job-results-container:nth-of-type(2) > search-job-cards > mat-accordion.mat-accordion.cards > mat-expansion-panel",
  "fields": {
    "title": "mat-panel-title p.job-title a.job-title-link span",
    "location": "mat-panel-description .label-value.location",
    "category": "mat-panel-description .categories.label-value",
    "req_id": "mat-panel-title p.req-id span"
  },
  "url_mode": "href",
  "url_selector": "mat-panel-title p.job-title a.job-title-link",
  "wait_after_click_ms": 2000,
  "pre_actions": [
    {
      "action": "wait_for_content",
      "timeout_ms": 15000
    }
  ],
  "detail": {
    "container_selector": "#all-content > descriptions-app > div.job-description-container",
    "fields": {
      "description": "article#description-body",
      "location": "li#header-locations",
      "department": "li#header-categories",
      "salary": "li#header-tags5"
    },
    "wait_ms": 2000
  }
}