{
  "domain": "careers.te.com",
  "name": "TE招聘",
  "card_selector": "li[data-testid=\"jobCard\"]",
  "fields": {
    "title": "a[data-testid^=\"jobCardTitle\"]",
    "department": "div[data-testid=\"jobCardFooter\"] > div:nth-child(1) > span:nth-child(2)",
    "job_family": "div[data-testid=\"jobCardFooter\"] > div:nth-child(2) > span:nth-child(2)"
  },
  "url_mode": "href",
  "url_selector": "a[data-testid^=\"jobCardTitle\"]",
  "wait_after_click_ms": 2000,
  "pre_actions": [
    {
      "action": "wait_for_content",
      "timeout_ms": 15000
    }
  ]
}