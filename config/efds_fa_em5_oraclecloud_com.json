{
  "domain": "efds.fa.em5.oraclecloud.com",
  "name": "Ford 招聘站点",
  "card_selector": "#panel-list > li",
  "fields": {
    "title": ".job-tile .job-tile__title",
    "location": ".job-tile .job-list-item__job-info-item:first-child .job-list-item__job-info-value",
    "date": ".job-tile .job-list-item__job-info-item:nth-child(2) .job-list-item__job-info-value",
    "description": ".job-tile .job-list-item__description"
  },
  "url_mode": "href",
  "url_selector": "a.job-list-item__link",
  "wait_after_click_ms": 2000,
  "pre_actions": [
    {
      "action": "wait_for_content",
      "timeout_ms": 15000
    }
  ]
}