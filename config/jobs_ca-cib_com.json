{
  "domain": "jobs.ca-cib.com",
  "name": "CA CIB 招聘",
  "card_selector": "#main > div.ts-related-offers__row.text-center > div",
  "fields": {
    "title": ".ts-offer-card__title-link",
    "category": ".ts-offer-card-content__list li:nth-child(1)",
    "location": ".ts-offer-card-content__list li:nth-child(3)"
  },
  "url_mode": "href",
  "url_selector": ".ts-offer-card__title-link",
  "wait_after_click_ms": 2000,
  "pre_actions": [
    {
      "action": "wait_for_content",
      "timeout_ms": 15000
    }
  ]
}