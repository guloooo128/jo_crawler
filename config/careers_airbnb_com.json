{
  "domain": "careers.airbnb.com",
  "name": "Airbnb 招聘",
  "card_selector": "div.wrapper:nth-of-type(1) > div.section-container:nth-of-type(2) > div.inner-flex.mb-12:nth-of-type(2) > ul.job-list.w-full > li",
  "fields": {
    "title": "span.text-size-4 > a",
    "department": "div.flex > span:nth-child(1)",
    "type": "div.flex > span:nth-child(3)",
    "location": "div:nth-child(2) > span"
  },
  "url_mode": "href",
  "url_selector": "span.text-size-4 > a",
  "wait_after_click_ms": 2000,
  "pre_actions": [
    {
      "action": "wait_for_content",
      "timeout_ms": 15000
    }
  ]
}