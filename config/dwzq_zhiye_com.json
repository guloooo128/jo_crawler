{
  "domain": "dwzq.zhiye.com",
  "name": "东吴证券招聘",
  "card_selector": "[class*='STListItem']",
  "fields": {
    "title": "[class*='STJobTitle'] span",
    "location": "[class*='STLabelSection'] > [class*='STJobLabel']:nth-of-type(3) [class*='STLabelText']",
    "department": "[class*='STLabelSection'] > [class*='STJobLabel']:nth-of-type(4) [class*='STLabelText']",
    "date": "[class*='STJobTime']"
  },
  "url_mode": "click_newtab",
  "url_selector": "[class*='STDetailBtn']",
  "wait_after_click_ms": 2000,
  "pre_actions": [
    {
      "action": "wait_for_content",
      "timeout_ms": 15000
    }
  ]
}