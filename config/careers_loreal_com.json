{
  "domain": "careers.loreal.com",
  "name": "欧莱雅招聘",
  "card_selector": "#main > section.module.module--search-jobs:nth-of-type(4) > div.module__wrapper.module__wrapper--bgcolor--2 > div.section--search-jobs.section--pad > div.section__content__results:nth-of-type(3) > article",
  "fields": {
    "title": ".article__header__text__title a",
    "location": ".article__header__text__subtitle span:nth-child(1)",
    "date": ".article__header__text__subtitle span:nth-child(2)"
  },
  "url_mode": "href",
  "url_selector": ".article__header__text__title a",
  "wait_after_click_ms": 2000,
  "pre_actions": [
    {
      "action": "wait_for_content",
      "timeout_ms": 15000
    }
  ]
}