{
  "domain": "careers.cbre.com",
  "name": "CBRE 招聘",
  "card_selector": "#main > div.main__wrapper > div.main__content.clearfix > section.section.section--search-jobs:nth-of-type(1) > div.section__content > div.section__content__results:nth-of-type(2) > article",
  "fields": {
    "title": ".article__header__text__title > a",
    "job_id": ".article__header__text__subtitle > span:nth-of-type(1)",
    "date": ".article__header__text__subtitle > span:nth-of-type(2)",
    "location": ".article__header__text__subtitle > span:nth-of-type(3)"
  },
  "url_mode": "href",
  "url_selector": ".article__header__text__title > a",
  "wait_after_click_ms": 2000,
  "pre_actions": [
    {
      "action": "wait_for_content",
      "timeout_ms": 15000
    }
  ]
}