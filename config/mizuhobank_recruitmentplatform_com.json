{
  "domain": "mizuhobank.recruitmentplatform.com",
  "name": "瑞穗银行招聘",
  "card_selector": "#talentlinkJobsList > div.jlist-tile",
  "fields": {
    "title": ".jlist-tile-wrapper h1 a",
    "location": ".list-group li:nth-child(2)",
    "department": ".list-group li:nth-child(3)",
    "date": ".list-group li:nth-child(4)"
  },
  "url_mode": "href",
  "url_selector": ".jlist-tile-wrapper a.btn",
  "wait_after_click_ms": 2000,
  "pre_actions": [
    {
      "action": "wait_for_content",
      "timeout_ms": 15000
    }
  ]
}