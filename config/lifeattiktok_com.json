{
  "domain": "lifeattiktok.com",
  "name": "TikTok 招聘",
  "card_selector": "a[href^='https://lifeattiktok.com/search/']",
  "fields": {
    "title": "div.border-b span.font-bold",
    "location": "div.border-b div[class*='gap-[24px]'] > div:nth-child(1) span",
    "department": "div.border-b div[class*='gap-[24px]'] > div:nth-child(2) span",
    "job_type": "div.border-b div[class*='gap-[24px]'] > div:nth-child(3) span",
    "category": "div.border-b div[class*='gap-[24px]'] > div:nth-child(4) span"
  },
  "url_mode": "href",
  "url_selector": "",
  "wait_after_click_ms": 2000,
  "pre_actions": [
    {
      "action": "wait_for_content",
      "timeout_ms": 15000
    }
  ]
}