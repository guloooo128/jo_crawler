  },
  "url_mode": "href",
  "url_selector": "h3.list-group-item-heading a",
  "wait_after_click_ms": 2000,
  "pre_actions": [
    {
      "action": "wait_for_content",
      "timeout_ms": 15000
    }
  ]
}