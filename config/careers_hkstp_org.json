{
  "domain": "careers.hkstp.org",
  "name": "香港科技园招聘",
  "card_selector": "#searchresults > tbody > tr",
  "fields": {
    "title": ".colTitle .jobTitle-link",
    "department": ".colDepartment .jobDepartment",
    "category": ".colFacility .jobFacility",
    "date": ".colDate .jobDate"
  },
  "url_mode": "href",
  "url_selector": ".colTitle .jobTitle-link",
  "wait_after_click_ms": 2000,
  "pre_actions": [
    {
      "action": "wait_for_content",
      "timeout_ms": 15000
    }
  ]
}