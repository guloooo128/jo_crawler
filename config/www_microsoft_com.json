{
  "domain": "www.microsoft.com",
  "name": "微软研究",
  "card_selector": "article.card.card--event",
  "fields": {
    "title": ".card__heading a",
    "date": ".card__date",
    "location": ".card__meta p span:last-child",
    "description": ".card-body > p"
  },
  "url_mode": "href",
  "url_selector": ".card__heading a",
  "wait_after_click_ms": 2000,
  "pre_actions": [
    {
      "action": "wait_for_content",
      "timeout_ms": 15000
    }
  ]
}