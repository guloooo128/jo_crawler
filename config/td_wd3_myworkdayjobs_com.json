{
  "domain": "td.wd3.myworkdayjobs.com",
  "name": "TD Bank 招聘",
  "card_selector": "ul[role=\"list\"] > li",
  "fields": {
    "title": "[data-automation-id=\"jobTitle\"]",
    "location": "[data-automation-id=\"locations\"] dd",
    "remote_type": "[data-automation-id=\"remoteType\"] dd",
    "date": "[data-automation-id=\"postedOn\"] dd",
    "department": "[data-automation-id=\"subtitle\"] li:nth-child(2)"
  },
  "url_mode": "href",
  "url_selector": "[data-automation-id=\"jobTitle\"]",
  "wait_after_click_ms": 2000,
  "pre_actions": [
    {
      "action": "wait_for_content",
      "timeout_ms": 15000
    }
  ]
}