{
  "domain": "apply.deloitte.co.uk",
  "name": "德勤英国招聘",
  "card_selector": "#main > div.main__wrapper > div.main__content > section.section.section--search-jobs > div.section__content.section__content--pad-alt:nth-of-type(3) > div.section__content__results:nth-of-type(2) > article",
  "fields": {
    "title": ".article__header__text__title a",
    "location": ".article__header__text__subtitle span:nth-child(1)",
    "department": ".article__header__text__subtitle span:nth-child(2)",
    "date": ".article__header__text__subtitle span:nth-child(3)"
  },
  "url_mode": "href",
  "url_selector": ".article__header__text__title a",
  "wait_after_click_ms": 2000,
  "pre_actions": [
    {
      "action": "wait_for_content",
      "timeout_ms": 15000
    }
  ]
}