{
  "domain": "careers.hcltech.com",
  "name": "HCL Tech 招聘",
  "card_selector": "#jobSearch_searchGridComponent > div > div:nth-of-type(2) > div.maincontent:nth-of-type(2) > div > ul > li",
  "fields": {
    "title": "a[class*='jobCardTitle']",
    "country": "[class*='jobCardFooterContainer'] > div:nth-of-type(2) [class*='jobCardFooterValue']",
    "location": "[class*='jobCardFooterContainer'] > div:nth-of-type(3) [class*='jobCardFooterValue']"
  },
  "url_mode": "href",
  "url_selector": "a[class*='jobCardTitle']",
  "wait_after_click_ms": 2000,
  "pre_actions": [
    {
      "action": "wait_for_content",
      "timeout_ms": 15000
    }
  ]
}